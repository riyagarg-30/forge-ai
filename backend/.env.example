PORT=5000
SUPABASE_URL=your_key
SUPABASE_SERVICE_ROLE_KEY=your-secret-key
FRONTEND_ORIGIN=http://localhost:5173

# Build Studio
# Image generation uses Pollinations.ai's free Flux model — no key needed.
# Optional: get a free token at https://enter.pollinations.ai for a higher
# rate limit and no watermark. Leave blank to use it fully anonymously.
POLLINATIONS_API_TOKEN=
BUILD_STUDIO_BUCKET=build-studio-assets

# Build Studio — template code generation
# AI_PROVIDER selects which provider aiProvider.js dispatches to (currently
# only "gemini" is implemented; groq/openai can be added later without
# changing any caller).
AI_PROVIDER=gemini
GEMINI_API_KEY=your-secret-key
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_MS=120000
