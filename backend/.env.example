PORT=5000
SUPABASE_URL=your_key
SUPABASE_SERVICE_ROLE_KEY=your-secret-key
FRONTEND_ORIGIN=http://localhost:5173

# Research/Market/Legal agents — optional live web search grounding via
# SerpApi (https://serpapi.com/manage-api-key). Leave blank to have those
# agents run on the LLM's own knowledge with no search results.
SERPAPI_KEY=

# Build Studio — template code generation
# AI_PROVIDER selects which provider aiProvider.js dispatches to (currently
# only "gemini" is implemented; groq/openai can be added later without
# changing any caller).
AI_PROVIDER=gemini
GEMINI_API_KEY=your-secret-key
GEMINI_MODEL=gemini-flash-latest
GEMINI_TIMEOUT_MS=120000
